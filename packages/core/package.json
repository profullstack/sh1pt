{
  "name": "@profullstack/sh1pt-core",
  "version": "0.1.4",
  "description": "Core interfaces and contract-test runners for sh1pt adapters.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/profullstack/sh1pt.git",
    "directory": "packages/core"
  },
  "homepage": "https://sh1pt.com",
  "bugs": "https://github.com/profullstack/sh1pt/issues",
  "keywords": [
    "sh1pt",
    "devtools",
    "publish",
    "adapter"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/index.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./testing": {
        "types": "./dist/testing/index.d.ts",
        "import": "./dist/testing/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "vitest": "*"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  }
}
